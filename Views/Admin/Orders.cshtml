@model List<Kurs_HTML.Models.OrderViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Справочник заказов";
}

<h2>@ViewData["Title"]</h2>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>№</th>
            <th>Услуга</th>
            <th>Дата создания</th>
            <th>Запланировано</th>
            <th>Исполнитель</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
    @for (int i = 0; i < Model.Count; i++)
    {
        var o = Model[i];
        <tr>
            <td>@(i + 1)</td>
            <td>@o.ServiceName</td>
            <td>@o.DateCreated.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@o.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@o.PerformerName</td>
            <td>@o.Name</td> <!-- o.Name = OrderStatus.Name -->
            <td>
                <a asp-action="EditOrder" asp-route-id="@o.OrderId" class="btn btn-sm btn-primary">Ред.</a>
                <form asp-action="DeleteOrder" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@o.OrderId" />
                    <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Удалить этот заказ?');">
                        Удал.
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
<style>
    table tr td,
    table tr th {
        color: white !important;
    }
</style>