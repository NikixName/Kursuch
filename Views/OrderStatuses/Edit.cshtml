@model Kurs_HTML.Models.OrderStatus
@{
    Layout = "_Layout";
    ViewData["Title"] = "Редактировать статус заказа";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Edit" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <input asp-for="OrderStatusId" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Название статуса</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Отмена</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
