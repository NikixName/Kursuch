@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var role = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        @* Если дочернее представление определило секцию “Title”, то выводим её + “ - Clean Motors”. 
           Иначе просто “Clean Motors”. *@
        @if (IsSectionDefined("Title"))
        {
            <text>
                @RenderSection("Title") - Clean Motors
            </text>
        }
        else
        {
            <text>Clean Motors</text>
        }
    </title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Kurs_HTML.styles.css" asp-append-version="true" />
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index1">
            Clean Motors
        </a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index1">Главная</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Table">Услуги</a>
                </li>
                @if (role == "Administrator")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Orders">Справочник заказов</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="CompletedOrders">Выполненные заказы</a>
                    </li>
                }
            </ul>
            @if (HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null)
            {
                <form asp-controller="Home" asp-action="Logout" method="post" class="d-flex">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light">Выйти</button>
                </form>
            }
            else
            {
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="SignIn">Войти</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Register">Регистрация</a></li>
                </ul>
            }
        </div>
    </div>
</nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-center py-3">
        <div class="container text-muted">
            &copy; 2025 - Clean Motors
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
