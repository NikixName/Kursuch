@using Microsoft.AspNetCore.Http
@model Kurs_HTML.Models.TableViewModel

@{
    Layout = null;
    var role = Context.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Каталог услуг – Clean Motors</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="~/css/decoratetable.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-gray-900 text-gray-200">

  <header class="flex justify-between items-center p-4">
    <!-- Кнопка назад на Index1 -->
    <a asp-controller="Home" asp-action="Index1"
       class="bg-yellow-500 hover:bg-yellow-600 text-black px-4 py-2 rounded">
      ← На главную
    </a>

    @* Для администратора — ссылка на управление услугами *@
    @if (role == "Administrator")
    {
      <a asp-controller="Services" asp-action="Index"
         class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded">
        Управление услугами
      </a>
    }
  </header>

  <main class="service-table-container p-4">
    <table class="service-table w-full">
      <thead>
        <tr class="text-black bg-yellow-500">
          <th class="py-3 px-4 rounded-tl-lg">Услуга</th>
          <th class="text-center py-3 px-4">Категория</th>
          <th class="text-center py-3 px-4">Стоимость</th>
          <th class="text-center py-3 px-4">Время</th>
          <th class="text-center py-3 px-4">Наличие</th>
          <th class="text-center py-3 px-4 rounded-tr-lg">Действия</th>
        </tr>
      </thead>
      <tbody>
      @foreach (var s in Model.Services)
      {
        <tr class="hover:bg-gray-700 transition">
          <td class="py-3 px-4">
            <div class="font-bold">@s.Name</div>
            @if (!string.IsNullOrEmpty(s.Notes))
            {
              <div class="text-sm text-gray-400">@s.Notes</div>
            }
          </td>
          <td class="text-center py-3 px-4">
            <span class="bg-yellow-500 text-black px-2 py-1 rounded text-xs font-bold">
              @s.Category
            </span>
          </td>
          <td class="text-center py-3 px-4">
            <div class="font-bold">@String.Format("{0:N0} ₽", s.BasePrice)</div>
            @if (!string.IsNullOrEmpty(s.DiscountText))
            {
              <div class="text-sm text-gray-400">@s.DiscountText</div>
            }
          </td>
          <td class="text-center py-3 px-4">
            <div class="font-bold">@s.Duration</div>
          </td>
          <td class="text-center py-3 px-4">
            @if (s.Available)
            {
              <span class="availability-dot available mr-1"></span><span>В наличии</span>
            }
            else
            {
              <span class="availability-dot unavailable mr-1"></span><span>Нет мест</span>
            }
          </td>
          <td class="text-center py-3 px-4 space-x-2">
            @* Запись доступна только клиентам *@
            @if (role == "Client")
            {
              @if (s.Available)
              {
                <a asp-action="Book"
                   asp-route-serviceId="@s.ServiceId"
                   class="bg-yellow-500 text-black px-3 py-1 rounded-lg font-bold hover:bg-yellow-600 transition text-sm"
                   aria-disabled="false">
                  Записаться
                </a>
              }
              else
              {
                <span class="bg-gray-600 text-gray-400 px-3 py-1 rounded-lg font-bold cursor-not-allowed text-sm"
                      aria-disabled="true">
                  Записаться
                </span>
              }
            }

            @* CRUD для администратора *@
            @if (role == "Administrator")
            {
              <a asp-controller="Services" asp-action="Edit" asp-route-id="@s.ServiceId"
                 class="bg-blue-500 hover:bg-blue-600 text-white px-2 py-1 rounded text-sm">✎</a>
              <a asp-controller="Services" asp-action="Delete" asp-route-id="@s.ServiceId"
                 class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded text-sm">🗑</a>
            }
          </td>
        </tr>
      }
      </tbody>
    </table>
  </main>

</body>
</html>
