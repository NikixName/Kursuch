@model Kurs_HTML.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Регистрация</title>
  <link rel="stylesheet" href="~/css/face.css" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white min-h-screen">

    <div class="flex justify-center py-4"></div>
  <a asp-action="Index" asp-controller="Home" class="flex items-center gap-2">
    <img src="~/images/logo.png" alt="Clean Motors" class="w-16 h-16 object-contain" />
    <span class="text-yellow-500 text-2xl font-bold">Clean Motors</span>
  </a>
</div>

  <div class="flex items-center justify-center h-full p-4">
    <div class="bg-black/70 backdrop-blur-sm rounded-[2rem] p-8 w-full max-w-md">
      <h1 class="text-2xl text-yellow-500 mb-6 text-center">Регистрация</h1>

      <form asp-action="Register" method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <div>
          <label asp-for="FirstName" class="block text-yellow-500 mb-1">Имя:</label>
          <input asp-for="FirstName"
                 placeholder="Не более 10 символов"
                 class="w-full px-4 py-2 bg-gray-800 rounded text-white focus:outline-yellow-500" />
          <span asp-validation-for="FirstName" class="text-red-500 text-sm"></span>
        </div>

        <div>
          <label asp-for="LastName" class="block text-yellow-500 mb-1">Фамилия:</label>
          <input asp-for="LastName"
                 placeholder="Не более 10 символов"
                 class="w-full px-4 py-2 bg-gray-800 rounded text-white focus:outline-yellow-500" />
          <span asp-validation-for="LastName" class="text-red-500 text-sm"></span>
        </div>

        <div>
          <label asp-for="Email" class="block text-yellow-500 mb-1">Почта gmail:</label>
          <input asp-for="Email"
                 placeholder="Не более 256 символов"
                 class="w-full px-4 py-2 bg-gray-800 rounded text-white focus:outline-yellow-500" />
          <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
        </div>

        <div>
          <label asp-for="Password" class="block text-yellow-500 mb-1">Пароль:</label>
          <input asp-for="Password" type="password"
                 placeholder="Не более 128 символов"
                 class="w-full px-4 py-2 bg-gray-800 rounded text-white focus:outline-yellow-500" />
          <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex gap-4">
          <button type="submit"
                  class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-black font-semibold py-2 rounded">
            Отправить
          </button>
          <button type="reset"
                  class="flex-1 bg-gray-700 hover:bg-gray-600 text-white font-semibold py-2 rounded">
            Начать заново
          </button>
        </div>

        <div class="text-center pt-4">
          <span class="text-yellow-500">Уже есть аккаунт?</span>
          <a asp-action="SignIn"
             class="inline-block ml-2 bg-yellow-500 hover:bg-yellow-600 text-black py-2 px-4 rounded font-semibold">
            Войти
          </a>
        </div>

      </form>

      <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    </div>
  </div>

</body>
</html>
