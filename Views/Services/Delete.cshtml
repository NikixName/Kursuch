@model Kurs_HTML.Models.ServiceViewModel
@{
  Layout = "_Layout";
  ViewData["Title"] = "Удалить услугу";
}
<h1>@ViewData["Title"]</h1>
<p>Вы уверены, что хотите удалить «<strong>@Model.Name</strong>»?</p>
<form asp-action="DeleteConfirmed" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="ServiceId" name="serviceId" />
  <button type="submit" class="btn btn-danger">Да, удалить</button>
  <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>
