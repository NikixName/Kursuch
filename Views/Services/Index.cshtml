@model IEnumerable<Kurs_HTML.Models.ServiceViewModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Справочник услуг";
}

<div class="container mt-4">
    <h1 class="text-white mb-3">@ViewData["Title"]</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Добавить услугу
        </a>
    </p>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Длительность</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Name</td>
                    <td>@s.Category</td>
                    <td>@String.Format("{0:N0} ₽", s.BasePrice)</td>
                    <td>@s.Duration</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@s.ServiceId" class="text-info me-2">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@s.ServiceId" class="text-danger">
                            <i class="fas fa-trash-alt"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
